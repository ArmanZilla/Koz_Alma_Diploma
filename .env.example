# ═══════════════════════════════════════════════════════════════════════
# KozAlma AI — Environment Variables
#
# Copy this file to backend/.env and fill in real values.
#   cp .env.example backend/.env
#
# NEVER commit backend/.env to git!
# ═══════════════════════════════════════════════════════════════════════

# ── Environment ────────────────────────────────────────────────────────
# Controls CORS, logging, fail-fast, security defaults.
# Values: dev | staging | prod
ENVIRONMENT=dev

# ── CORS ───────────────────────────────────────────────────────────────
# Comma-separated allowed origins.  Leave empty for auto-detect:
#   dev  → ["*"] (allow all)
#   prod → ["http://localhost:3000", "http://localhost:8000"]
# Set explicitly for production, e.g.: https://app.kozalma.kz,https://admin.kozalma.kz
ALLOWED_ORIGINS=

# ── S3 / Yandex Object Storage ────────────────────────────────────────
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=koz-alma-unknown
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1

# ── Admin Panel ────────────────────────────────────────────────────────
# ⚠️  Change these from defaults before deploying!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
ADMIN_SESSION_SECRET=generate-a-random-string-here

# ── ML Model Paths (relative to backend/) ──────────────────────────────
YOLO_WEIGHTS_PATH=weights/best.pt
MIDAS_MODEL=MiDaS_small
CONFIDENCE_THRESHOLD=0.35
UNKNOWN_THRESHOLD=0.30

# ── Auto-Label Pipeline ───────────────────────────────────────────────
AUTO_LABEL_ENABLED=true
AUTO_LABEL_MIN_CONF=0.15

# ── TTS ────────────────────────────────────────────────────────────────
TTS_DEFAULT_LANG=ru
TTS_DEFAULT_SPEED=1.0

# ── Kazakh TTS (Piper — offline) ──────────────────────────────────────
# Download models from: https://huggingface.co/rhasspy/piper-voices
KZ_TTS_ENABLED=false
KZ_TTS_MODEL_PATH=models/kk_KZ-issai-high.onnx
KZ_TTS_CONFIG_PATH=models/kk_KZ-issai-high.onnx.json
KZ_TTS_USE_CUDA=false

# ── Server ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Redis ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Docker Compose: REDIS_URL=redis://redis:6379/0

# ── Database ───────────────────────────────────────────────────────────
# SQLite (dev):  sqlite+aiosqlite:///./koz_alma.db
# PostgreSQL:    postgresql+asyncpg://user:pass@host:5432/kozalma
DATABASE_URL=sqlite+aiosqlite:///./koz_alma.db

# ── OTP Authentication ────────────────────────────────────────────────
OTP_TTL_SECONDS=300
OTP_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_LOCK_SECONDS=600
# ⚠️  Set to false in production!
OTP_DEV_MODE=true
# ⚠️  Generate a random string: python -c "import secrets; print(secrets.token_hex(32))"
OTP_HMAC_SECRET=change-me-otp-hmac-secret
OTP_SALT=

# ── JWT ────────────────────────────────────────────────────────────────
# ⚠️  Generate a random string: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRES_MIN=30
REFRESH_TOKEN_EXPIRES_DAYS=30

# ── Admin Auto-Identifiers ────────────────────────────────────────────
# Comma-separated emails/phones that auto-get admin role on first login.
ADMIN_IDENTIFIERS=

# ── SMTP (Email OTP) ──────────────────────────────────────────────────
# For Gmail: use App Password (2FA must be enabled)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Twilio (WhatsApp OTP) ─────────────────────────────────────────────
# Leave empty to disable WhatsApp channel.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Rate Limiting ──────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_SCAN=30/minute
RATE_LIMIT_TTS=60/minute
RATE_LIMIT_OTP=5/minute
RATE_LIMIT_AUTH=20/minute

# ── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Set to true for structured JSON logs (production log aggregation)
LOG_JSON=false

# ── Dataset (ML training scripts) ─────────────────────────────────────
DATA_YAML_PATH=../data/data.yaml
